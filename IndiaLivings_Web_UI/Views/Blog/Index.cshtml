@model List<IndiaLivings_Web_DAL.Models.BlogModel>

@{
    ViewBag.Title = "Blogs";
}

<!DOCTYPE html>

<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Blogs - Modern</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <style>
        /* Page basics */
        html, body {
            height: 100%;
            margin: 0;
            font-family: Inter, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial;
            /* background: linear-gradient(135deg, #f3e8ff, #e9d5ff); */
            color: #1f2937;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        /* Container centered and constrained */
        .container {
            max-width: 1100px;
            margin: 0 auto;
            padding: 24px;
            box-sizing: border-box;
        }

        /* Hero */
        .blog-hero {
            padding: 48px 0 24px;
            text-align: center;
        }

        .blog-hero h1 {
            font-size: 40px;
            margin: 0 0 8px;
            line-height: 1.1;
        }

        .blog-hero p {
            color: #6b7280;
            margin: 0;
        }

        .hero-actions {
            display: flex;
            gap: 8px;
            justify-content: center;
            margin-top: 18px;
            flex-wrap: wrap;
        }

        .searchbar {
            width: 420px;
            max-width: 100%;
            padding: 10px 14px;
            border-radius: 999px;
            border: 1px solid #e5e7eb;
            box-sizing: border-box;
        }

        .write-btn {
            margin-left: 4px;
            padding: 10px 14px;
            border-radius: 8px;
            background: linear-gradient(90deg,#10b981,#06b6d4);
            color: white;
            text-decoration: none;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        /* Filters */
        .filters {
            display:flex;
            gap:8px;
            flex-wrap:wrap;
            align-items:center;
            justify-content:center;
            margin:18px 0;
        }

        .filter-btn{
            padding:8px 12px;
            border-radius:999px;
            border:1px solid #e5e7eb;
            background:white;
            cursor:pointer;
            color:#374151;
            font-weight:600;
        }

        .filter-btn.active{background:linear-gradient(90deg,#0ea5e9,#3b82f6);color:white;border-color:transparent}

        /* Grid and cards */
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fill,minmax(320px,1fr));
            gap: 20px;
            align-items: start;
        }

        .card {
            background: #fff;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 6px 18px rgba(15,23,42,0.08);
            display: flex;
            flex-direction: column;
            height: 100%;
        }

        .card .thumb {
            height: 180px;
            background: #e6eef8;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #0b5ed7;
            overflow: hidden;
        }

        .card .thumb img { width: 100%; height: 100%; object-fit: cover; display:block }

        .card .body {
            padding: 18px;
            display: flex;
            flex-direction: column;
            gap: 8px;
            flex: 1 1 auto;
        }

        .card h3 { font-size: 20px; margin: 0 }

        .meta { display: flex; gap: 12px; color: #6b7280; font-size: 13px }

        .excerpt { color: #374151; font-size: 14px; line-height: 1.4 }

        .read-btn { margin-top: auto; display: inline-block; padding: 10px 14px; border-radius: 8px; background: linear-gradient(90deg,#0ea5e9,#3b82f6); color: white; text-decoration: none; font-weight: 600 }

        /* Responsive adjustments */
        @@media (max-width: 900px) {
            .grid { grid-template-columns: repeat(auto-fill,minmax(260px,1fr)); gap: 16px }
            .blog-hero h1 { font-size: 32px }
        }

        @@media (max-width: 520px) {
            .searchbar { width: 100%; }
            .filters { justify-content: center }
            .grid { grid-template-columns: 1fr }
        }

    </style>
</head>
<body>

    <div class="blog-hero">
        <div class="container">
            <h1>Insights & Stories</h1>
            <p>Latest news, tips, and product updates from our team.</p>

            <div class="hero-actions">
                <input class="searchbar" id="search" placeholder="Search posts by title or tag..." />
                <a href="@Url.Action("BlogPost", "User")" class="write-btn"><i class="fas fa-plus"></i><span>Write Post</span></a>
            </div>
        </div>
    </div>

    <div class="container">

        <!-- Category filters -->
        @if (Model != null && Model.Any()) {
            var categories = Model.Select(m => m.categoryName ?? "General").Distinct().ToList();
            <div class="filters" id="category-filters">
                <button class="filter-btn active" data-cat="">All</button>
                @foreach(var c in categories) {
                    <button class="filter-btn" data-cat="@c">@c</button>
                }
            </div>
        }

        <div id="grid" class="grid">
            @if (Model == null || !Model.Any()) {
                <div style="grid-column:1/-1;text-align:center;padding:40px;background:#fff;border-radius:12px;">No blog posts yet.</div>
            }
            else {
                foreach (var b in Model) {
                    var cat = b.categoryName ?? "General";
                    <div class="card" data-category="@cat">
                        <div class="thumb">
                            @{ var hasImage = b.featuredImage != null && b.featuredImage.Length > 0; var imageSrc = hasImage ? $"data:image/png;base64,{Convert.ToBase64String(b.featuredImage)}" : Url.Content("~/images/no-image.png"); }
                            <img src="@imageSrc" alt="blog" />
                        </div>
                        <div class="body">
                            <div class="meta"><span>@b.publishedDate.ToString("dd MMM yyyy")</span><span>•</span><span>@cat</span></div>
                            <h3>@b.title</h3>
                            <p class="excerpt">@((b.summary?.Length > 180) ? b.summary.Substring(0, 180) + "..." : b.summary)</p>
                            <a class="read-btn" href="@Url.Action("BlogDetails", "Dashboard", new { blogId = b.blogId })">Read</a>
                        </div>
                    </div>
                }
            }
        </div>

    </div>

    <script>
        // Current active category filter
        let currentCategory = '';

        // Hook up filter buttons (guard existence)
        document.querySelectorAll('#category-filters .filter-btn').forEach(btn=>{
            btn.addEventListener('click', function(){
                document.querySelectorAll('#category-filters .filter-btn').forEach(b=>b.classList.remove('active'));
                this.classList.add('active');
                currentCategory = this.getAttribute('data-cat') || '';
                applyFilters();
            });
        });

        const searchInput = document.getElementById('search');
        if (searchInput) searchInput.addEventListener('input', function(){ applyFilters(); });

        function applyFilters(){
            const q = (document.getElementById('search')?.value || '').toLowerCase().trim();
            const cards = document.querySelectorAll('#grid .card');
            const norm = s => (s||'').toString().toLowerCase().trim();
            cards.forEach(card=>{
                const title = norm(card.querySelector('h3')?.textContent);
                const excerpt = norm(card.querySelector('.excerpt')?.textContent);
                const cat = norm(card.getAttribute('data-category'));
                const matchesSearch = q === '' || title.includes(q) || excerpt.includes(q);
                const matchesCategory = currentCategory === '' || cat === norm(currentCategory);
                card.style.display = (matchesSearch && matchesCategory) ? '' : 'none';
            });
        }
    </script>
</body>
</html>